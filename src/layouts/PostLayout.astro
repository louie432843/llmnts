---
const { title, description } = Astro.props;
---

<html>
  <head>
    <title>{title} | LLMNTS</title>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      body {
        background: #0d0d0d;
        color: #f5f5f5;
        font-family: system-ui, -apple-system, sans-serif;
        max-width: 720px;
        margin: 60px auto;
        line-height: 1.7;
        padding: 0 20px;
      }
      header {
        margin-bottom: 60px;
        font-size: 0.9rem;
        letter-spacing: 0.08em;
      }
      nav a {
        color: #aaa;
        text-decoration: none;
        margin-right: 20px;
      }
      nav a:hover {
        color: #fff;
      }
      h1 {
        font-size: 2.4rem;
        margin-bottom: 24px;
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a href="/">LLMNTS</a>
      </nav>
    </header>

    <slot />
  </body>
</html>
