---
const { title, description } = Astro.props;
---

<html>
  <head>
    <title>{title} | LLMNTS</title>
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      body {
        background: #0d0d0d;
        color: #f5f5f5;
        font-family: system-ui, -apple-system, sans-serif;
        max-width: 720px;
        margin: 60px auto;
        line-height: 1.7;
        padding: 0 20px;
      }
      header {
        margin-bottom: 60px;
        font-size: 0.9rem;
        letter-spacing: 0.08em;
      }
      nav a {
        color: #aaa;
        text-decoration: none;
        margin-right: 20px;
      }
      nav a:hover {
        color: #fff;
      }
      h1 {
        font-size: 2.4rem;
        margin-bottom: 24px;
      }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a href="/">LLMNTS</a>
      </nav>
    </header>

    <div style="display:flex;align-items:center;gap:12px;margin-bottom:16px;">
      <img src="/images/clawndike-avatar.jpg" alt="Clawndike avatar" style="width:36px;height:36px;border-radius:50%;object-fit:cover;" />
      <span style="font-size:0.9rem;color:#888;">Co-authored by Clawndike</span>
    </div>
    <p style="color:#aaa;font-size:1.05rem;margin-bottom:40px;">{Astro.props.hook}</p>
    <slot />
  </body>
</html>
