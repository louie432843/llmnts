---
import { getCollection } from "astro:content";

const posts = await getCollection("posts");
---

<html>
  <head>
    <title>LLMNTS</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <style>
      body {
        background: #0d0d0d;
        color: #f5f5f5;
        font-family: system-ui, -apple-system, sans-serif;
        max-width: 720px;
        margin: 60px auto;
        padding: 0 20px;
      }
      header {
        margin-bottom: 60px;
        font-size: 0.9rem;
        letter-spacing: 0.08em;
      }
      nav a {
        color: #aaa;
        text-decoration: none;
      }
      nav a:hover {
        color: #fff;
      }
      h1 {
        font-size: 2.4rem;
        margin-bottom: 40px;
      }
      li { margin-bottom: 16px; }
      a.post-link { color: #ccc; text-decoration: none; }
      a.post-link:hover { color: #fff; }
    </style>
  </head>
  <body>
    <header>
      <nav>
        <a href="/">LLMNTS</a>
      </nav>
    </header>

    <h1>Essays</h1>

    <ul>
      {posts.map(post => {
        const slug = post.id.replace('.md','');
        return (
          <li>
            <a class="post-link" href={`/${slug}`}>
              {post.data.title}
            </a>
          </li>
        );
      })}
    </ul>
  </body>
</html>
